{
  "name": "prosecheck",
  "version": "0.1.1",
  "description": "LLM-powered code linter with natural-language rules",
  "license": "Apache-2.0",
  "author": "Promaia",
  "homepage": "https://github.com/Promaia/prosecheck",
  "repository": {
    "type": "git",
    "url": "https://github.com/Promaia/prosecheck.git"
  },
  "bugs": {
    "url": "https://github.com/Promaia/prosecheck/issues"
  },
  "keywords": [
    "linter",
    "lint",
    "llm",
    "claude",
    "natural-language",
    "code-review",
    "static-analysis",
    "sarif"
  ],
  "type": "module",
  "bin": {
    "prosecheck": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:slow": "vitest run --config vitest.config.slow.ts",
    "test:slow:verbose": "vitest run --config vitest.config.slow-verbose.ts",
    "test:prepare": "tsx scripts/prepare-scenario.ts",
    "self-prosecheck": "tsx src/cli.ts",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run format:check && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "yocto-spinner": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.2",
    "ink-testing-library": "^4.0.0",
    "jiti": "^2.6.1",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
